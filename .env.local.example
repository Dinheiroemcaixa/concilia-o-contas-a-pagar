# ─────────────────────────────────────────────────────────
#  Copie este arquivo para ".env.local" e preencha os valores
# ─────────────────────────────────────────────────────────

# ContaAzul — em: https://developers.contaazul.com → Meus Apps
CONTAAZUL_CLIENT_ID=SEU_CLIENT_ID
CONTAAZUL_CLIENT_SECRET=SEU_CLIENT_SECRET

# URL de retorno após login
# Desenvolvimento → http://localhost:3000/api/auth/callback
# Produção (Vercel) → https://seu-app.vercel.app/api/auth/callback
CONTAAZUL_REDIRECT_URI=http://localhost:3000/api/auth/callback

# URL pública do app (usada no logout)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — em: https://supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# Segredo de sessão — qualquer texto longo e aleatório (mín. 32 caracteres)
SESSION_SECRET=troque-por-um-texto-longo-e-aleatorio-aqui-32chars
